              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Devuelve cualquier código de estado `2xx` para confirmar la recepción."
          }
        },
        "summary": "Agente iniciado",
        "tags": [
          "Agent"
        ]
      }
    },
    "batchScrapeCompleted": {
