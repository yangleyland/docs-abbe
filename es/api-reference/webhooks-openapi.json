    "crawlCompleted": {
      "post": {
        "operationId": "crawlCompleted",
        "parameters": [
          {
            "$ref": "#/components/parameters/FirecrawlSignature"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
