                    "description": "El ID del trabajo del agente, que coincide con el `id` devuelto por `POST /agent`.",
                    "format": "uuid",
                    "type": "string"
                  },
                  "metadata": {
                    "$ref": "#/components/schemas/WebhookMetadata"
                  },
                  "success": {
                    "const": true,
