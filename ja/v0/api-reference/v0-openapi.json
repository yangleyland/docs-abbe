{
  "components": {
    "schemas": {
      "CrawlResponse": {
        "properties": {
          "jobId": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "CrawlStatusResponseObj": {
        "properties": {
          "content": {
            "type": "string"
          },
          "html": {
            "description": "`includeHtml` が true の場合、そのページの内容の HTML 版",
            "nullable": true,
            "type": "string"
          },
          "index": {
            "description": "クロールされたページの番号です。`partial_data` を利用する際に、データがどのページ由来かを特定するのに役立ちます。",
            "type": "integer"
          },
          "markdown": {
            "type": "string"
          },
          "metadata": {
            "properties": {
              "<any other metadata> ": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "language": {
                "nullable": true,
                "type": "string"
              },
              "pageError": {
                "description": "ページのエラーメッセージ",
                "nullable": true,
                "type": "string"
              },
              "pageStatusCode": {
                "description": "ページのステータスコード",
                "type": "integer"
              },
              "sourceURL": {
                "format": "uri",
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "rawHtml": {
            "description": "`includeRawHtml` が true の場合のページの生の HTML コンテンツ",
            "nullable": true,
            "type": "string"
          }
        },
        "type": "object"
      },
      "ScrapeResponse": {
        "properties": {
          "data": {
            "properties": {
              "content": {
                "type": "string"
              },
              "html": {
                "description": "`includeHtml` が true の場合、そのページのコンテンツの HTML 版",
                "nullable": true,
                "type": "string"
              },
              "llm_extraction": {
                "description": "LLM Extraction 使用時に表示されます。定義したスキーマに従ってページから抽出されたデータです。",
                "nullable": true,
                "type": "object"
              },
              "markdown": {
                "type": "string"
              },
              "metadata": {
                "properties": {
                  "<any other metadata> ": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "language": {
                    "nullable": true,
                    "type": "string"
                  },
                  "pageError": {
                    "description": "ページのエラーメッセージ",
                    "nullable": true,
                    "type": "string"
                  },
                  "pageStatusCode": {
                    "description": "ページのHTTPステータスコード",
                    "type": "integer"
                  },
                  "sourceURL": {
                    "format": "uri",
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "rawHtml": {
                "description": "`includeRawHtml` が true の場合のページの生の HTML コンテンツ",
                "nullable": true,
                "type": "string"
              },
              "warning": {
                "description": "LLM Extraction の使用時に表示されます。抽出に問題がある場合は、警告メッセージで通知されます。",
                "nullable": true,
                "type": "string"
              }
            },
            "type": "object"
          },
          "success": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "SearchResponse": {
        "properties": {
          "data": {
            "items": {
              "properties": {
                "content": {
                  "type": "string"
                },
                "markdown": {
                  "type": "string"
                },
                "metadata": {
                  "properties": {
                    "description": {
                      "type": "string"
                    },
                    "language": {
                      "nullable": true,
                      "type": "string"
                    },
                    "sourceURL": {
                      "format": "uri",
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "url": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "type": "array"
          },
          "success": {
            "type": "boolean"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {
      "email": "support@firecrawl.dev",
      "name": "Firecrawl Support",
      "url": "https://firecrawl.dev/support"
    },
    "description": "Webスクレイピングやクロール処理を行うためのFirecrawlサービス向けAPIです。",
    "title": "Firecrawl API",
    "version": "v0"
  },
  "openapi": "3.0.0",
  "paths": {
    "/crawl": {
      "post": {
        "operationId": "crawlUrls",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "crawlerOptions": {
                    "properties": {
                      "allowBackwardCrawling": {
                        "default": false,
                        "description": "クローラーが特定のURLから、そこに至るまでにリンクで辿ってきたページへ戻れるようにします。例えば、`example.com/product/123` から `example.com/product` へ戻るといった動作を可能にします。",
                        "type": "boolean"
                      },
                      "allowExternalContentLinks": {
                        "default": false,
                        "description": "クローラーが外部のウェブサイトへのリンクをたどれるようにします。",
                        "type": "boolean"
                      },
                      "excludes": {
                        "description": "除外対象のURLパターン",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "generateImgAltText": {
                        "default": false,
                        "description": "LLM を使って画像の代替テキストを生成（有料プランが必要）",
                        "type": "boolean"
                      },
                      "ignoreSitemap": {
                        "default": false,
                        "description": "クロール時にサイトマップを無視する",
                        "type": "boolean"
                      },
                      "includes": {
                        "description": "含める URL パターン",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "limit": {
                        "default": 10000,
                        "description": "クロールするページの最大数",
                        "type": "integer"
                      },
                      "maxDepth": {
                        "description": "入力したURLを基準としてクロールする最大の階層深さです。maxDepth が 0 の場合は、入力したURLのみをスクレイピングします。maxDepth が 1 の場合は、入力したURLと、その1階層下にあるすべてのページをスクレイピングします。maxDepth が 2 の場合は、入力したURLと、その2階層下までのすべてのページをスクレイピングします。より大きな値でも同様のルールで動作します。",
                        "type": "integer"
                      },
                      "mode": {
                        "default": "default",
                        "description": "使用するクロールモードです。Fast モードはサイトマップがないウェブサイトを通常の 4 倍の速度でクロールできますが、精度が低くなる可能性があり、JavaScript によるレンダリングに大きく依存するウェブサイトでは使用しないでください。",
                        "enum": [
                          "default",
                          "fast"
                        ],
                        "type": "string"
                      },
                      "returnOnlyUrls": {
                        "default": false,
                        "description": "true の場合、クロールステータスでは URL のみをリストとして返します。注意：レスポンスは data 内の URL のリストであり、ドキュメントのリストではありません。",
                        "type": "boolean"
                      }
                    },
                    "type": "object"
                  },
                  "pageOptions": {
                    "properties": {
                      "fullPageScreenshot": {
                        "default": false,
                        "description": "スクレイピング対象ページの全体が映ったスクリーンショットを含めてください。",
                        "type": "boolean"
                      },
                      "headers": {
                        "description": "リクエストに付与するヘッダー。クッキーや User-Agent などを送信するために使用できます。",
                        "type": "object"
                      },
                      "includeHtml": {
                        "default": false,
                        "description": "ページ内コンテンツの HTML バージョンを含めます。レスポンスには html キーが含まれます。",
                        "type": "boolean"
                      },
                      "includeRawHtml": {
                        "default": false,
                        "description": "ページの生の HTML コンテンツを含めます。レスポンスには rawHtml キーが含まれます。",
                        "type": "boolean"
                      },
                      "onlyIncludeTags": {
                        "description": "最終出力には、そのページ内に存在するタグ・クラス・ID のみを含めてください。値はカンマ区切りで指定します。例: 'script, .ad, #footer'",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "onlyMainContent": {
                        "default": false,
                        "description": "ヘッダーやナビゲーション、フッターなどを除いたページのメインコンテンツのみを返します。",
                        "type": "boolean"
                      },
                      "removeTags": {
                        "description": "ページから削除するタグ、クラス、ID を指定します。カンマ区切りの値で入力してください。例: 'script, .ad, #footer'",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "replaceAllPathsWithAbsolutePaths": {
                        "default": false,
                        "description": "画像およびリンクの相対パスをすべて絶対パスに置き換えます",
                        "type": "boolean"
                      },
                      "screenshot": {
                        "default": false,
                        "description": "スクレイピングしているページの上部のスクリーンショットを含めてください。",
                        "type": "boolean"
                      },
                      "waitFor": {
                        "default": 0,
                        "description": "ページ読み込みのために x ミリ秒待機してからコンテンツを取得します",
                        "type": "integer"
                      }
                    },
                    "type": "object"
                  },
                  "url": {
                    "description": "クロールの開始地点となるベースURL",
                    "format": "uri",
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CrawlResponse"
                }
              }
            },
            "description": "成功時のレスポンス"
          },
          "402": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Payment required to access this resource.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "お支払いが必要です"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Request rate limit exceeded. Please wait and try again later.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "リクエスト数が多すぎます"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "An unexpected error occurred on the server.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "サーバーエラー"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "オプションに応じて複数のURLをクロールする",
        "tags": [
          "Crawling"
        ]
      }
    },
    "/crawl/cancel/{jobId}": {
      "delete": {
        "operationId": "cancelCrawlJob",
        "parameters": [
          {
            "description": "クロールジョブのID",
            "in": "path",
            "name": "jobId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "description": "キャンセルを返します。",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "成功したレスポンス"
          },
          "402": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Payment required to access this resource.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "お支払いが必要です"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Request rate limit exceeded. Please wait and try again later.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "リクエストが多すぎます。"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "An unexpected error occurred on the server.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "サーバーエラー"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "クロールジョブをキャンセルする",
        "tags": [
          "Crawl"
        ]
      }
    },
    "/crawl/status/{jobId}": {
      "get": {
        "operationId": "getCrawlStatus",
        "parameters": [
          {
            "description": "クロールジョブのID",
            "in": "path",
            "name": "jobId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "current": {
                      "description": "現在のページ番号",
                      "type": "integer"
                    },
                    "data": {
                      "description": "ジョブから返されるデータ（実行中は null）",
                      "items": {
                        "$ref": "#/components/schemas/CrawlStatusResponseObj"
                      },
                      "type": "array"
                    },
                    "partial_data": {
                      "description": "クロール中のドキュメントは部分的に返されます（ストリーミング）。**この機能は現在アルファ版のため、破壊的な変更が発生する可能性があります。** ページの処理が完了すると、そのページが partial_data 配列に追加されるため、サイト全体のクロール完了を待つ必要はありません。クロールが完了すると、partial_data は空になり、結果は `data` に格納されます。レスポンスの配列内の項目数は最大 50 件です。配列に新しい項目が追加されると、最も古い項目（配列の先頭）が削除されます。",
                      "items": {
                        "$ref": "#/components/schemas/CrawlStatusResponseObj"
                      },
                      "type": "array"
                    },
                    "status": {
                      "description": "ジョブのステータス（completed／active／failed／paused）",
                      "type": "string"
                    },
                    "total": {
                      "description": "総ページ数",
                      "type": "integer"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "成功時のレスポンス"
          },
          "402": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Payment required to access this resource.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "お支払いが必要です"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Request rate limit exceeded. Please wait and try again later.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "リクエスト回数が多すぎます"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "An unexpected error occurred on the server.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "サーバーエラー"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "クロールジョブのステータスを取得する",
        "tags": [
          "Crawl"
        ]
      }
    },
    "/scrape": {
      "post": {
        "operationId": "scrapeAndExtractFromUrl",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "extractorOptions": {
                    "default": {},
                    "description": "ページ内容から構造化情報を抽出するためのオプションです。注意：LLM ベースの抽出はデフォルトでは行われず、明示的に設定された場合にのみ実行されます。`markdown` モードはスクレイピングした Markdown を単に返すだけのモードであり、スクレイピング時のデフォルトモードです。",
                    "properties": {
                      "extractionPrompt": {
                        "description": "ページからどのような情報を抽出するかを指定するプロンプト。LLM 抽出モードで使用されます。",
                        "type": "string"
                      },
                      "extractionSchema": {
                        "additionalProperties": true,
                        "description": "抽出するデータのスキーマ。LLM 抽出モードの場合にのみ必須です。",
                        "required": [
                          "company_mission",
                          "supports_sso",
                          "is_open_source"
                        ],
                        "type": "object"
                      },
                      "mode": {
                        "description": "使用する抽出モードです。`markdown`：スクレイピングしたMarkdownコンテンツをそのまま返し、LLMによる抽出は行いません。`llm-extraction`：クリーニングおよび解析済みコンテンツから、LLMを用いて情報を抽出します。`llm-extraction-from-raw-html`：生のHTMLから直接、LLMを用いて情報を抽出します。`llm-extraction-from-markdown`：Markdownコンテンツから、LLMを用いて情報を抽出します。",
                        "enum": [
                          "markdown",
                          "llm-extraction",
                          "llm-extraction-from-raw-html",
                          "llm-extraction-from-markdown"
                        ],
                        "type": "string"
                      }
                    },
                    "type": "object"
                  },
                  "pageOptions": {
                    "properties": {
                      "fullPageScreenshot": {
                        "default": false,
                        "description": "スクレイピングしているページの全体が写ったスクリーンショットを含めてください。",
                        "type": "boolean"
                      },
                      "headers": {
                        "description": "リクエストに付与するヘッダー。Cookie や User-Agent などを送信する際に使用します。",
                        "type": "object"
                      },
                      "includeHtml": {
                        "default": false,
                        "description": "ページ内コンテンツの HTML バージョンを含めます。レスポンスに html キーが追加されます。",
                        "type": "boolean"
                      },
                      "includeRawHtml": {
                        "default": false,
                        "description": "ページの生の HTML コンテンツを含めます。レスポンスに rawHtml キーが含まれます。",
                        "type": "boolean"
                      },
                      "onlyIncludeTags": {
                        "description": "最終的な出力には、ページ内に存在するタグ・クラス・id のみを含めてください。値はカンマ区切りで指定します。例: 'script, .ad, #footer'",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "onlyMainContent": {
                        "default": false,
                        "description": "ヘッダー、ナビゲーション、フッターなどを除いたページのメインコンテンツのみを返します。",
                        "type": "boolean"
                      },
                      "removeTags": {
                        "description": "ページから削除するタグ、クラス、ID を指定します。カンマ区切りの値で入力してください。例: 'script, .ad, #footer'",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "replaceAllPathsWithAbsolutePaths": {
                        "default": false,
                        "description": "画像やリンクの相対パスをすべて絶対パスに置き換える",
                        "type": "boolean"
                      },
                      "screenshot": {
                        "default": false,
                        "description": "スクレイピング対象のページの先頭部分のスクリーンショットを含めてください。",
                        "type": "boolean"
                      },
                      "waitFor": {
                        "default": 0,
                        "description": "コンテンツを取得する前に、ページの読み込みのために x ミリ秒待機します",
                        "type": "integer"
                      }
                    },
                    "type": "object"
                  },
                  "timeout": {
                    "default": 30000,
                    "description": "リクエストのタイムアウト時間（ミリ秒）",
                    "type": "integer"
                  },
                  "url": {
                    "description": "スクレイピング対象のURL",
                    "format": "uri",
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeResponse"
                }
              }
            },
            "description": "成功時のレスポンス"
          },
          "402": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Payment required to access this resource.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "お支払いが必要です"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Request rate limit exceeded. Please wait and try again later.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "リクエスト数が多すぎます"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "An unexpected error occurred on the server.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "サーバーエラー"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
