{
  "components": {
    "schemas": {
      "CrawlResponse": {
        "properties": {
          "jobId": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "CrawlStatusResponseObj": {
        "properties": {
          "content": {
            "type": "string"
          },
          "html": {
            "description": "当 `includeHtml` 为 true 时，页面内容的 HTML 版本",
            "nullable": true,
            "type": "string"
          },
          "index": {
            "description": "已抓取页面的编号。对于 `partial_data` 特别有用，这样你就能知道数据来自第几页。",
            "type": "integer"
          },
          "markdown": {
            "type": "string"
          },
          "metadata": {
            "properties": {
              "<any other metadata> ": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "language": {
                "nullable": true,
                "type": "string"
              },
              "pageError": {
                "description": "页面错误信息",
                "nullable": true,
                "type": "string"
              },
              "pageStatusCode": {
                "description": "页面状态码",
                "type": "integer"
              },
              "sourceURL": {
                "format": "uri",
                "type": "string"
              },
              "title": {
                "type": "string"
              }
            },
            "type": "object"
          },
          "rawHtml": {
            "description": "如果 `includeRawHtml` 为 true，则返回页面的原始 HTML 内容",
            "nullable": true,
            "type": "string"
          }
        },
        "type": "object"
      },
      "ScrapeResponse": {
        "properties": {
          "data": {
            "properties": {
              "content": {
                "type": "string"
              },
              "html": {
                "description": "当 `includeHtml` 为 true 时，该页面内容的 HTML 版本",
                "nullable": true,
                "type": "string"
              },
              "llm_extraction": {
                "description": "在使用 LLM Extraction 功能时显示。页面中根据已定义的 schema 提取出的数据。",
                "nullable": true,
                "type": "object"
              },
              "markdown": {
                "type": "string"
              },
              "metadata": {
                "properties": {
                  "<any other metadata> ": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "language": {
                    "nullable": true,
                    "type": "string"
                  },
                  "pageError": {
                    "description": "页面错误信息",
                    "nullable": true,
                    "type": "string"
                  },
                  "pageStatusCode": {
                    "description": "页面状态码",
                    "type": "integer"
                  },
                  "sourceURL": {
                    "format": "uri",
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  }
                },
                "type": "object"
              },
              "rawHtml": {
                "description": "如果 `includeRawHtml` 为 true，则为页面的原始 HTML 内容",
                "nullable": true,
                "type": "string"
              },
              "warning": {
                "description": "可在使用 LLM 提取时显示。警告消息会提示你提取过程中的任何问题。",
                "nullable": true,
                "type": "string"
              }
            },
            "type": "object"
          },
          "success": {
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "SearchResponse": {
        "properties": {
          "data": {
            "items": {
              "properties": {
                "content": {
                  "type": "string"
                },
                "markdown": {
                  "type": "string"
                },
                "metadata": {
                  "properties": {
                    "description": {
                      "type": "string"
                    },
                    "language": {
                      "nullable": true,
                      "type": "string"
                    },
                    "sourceURL": {
                      "format": "uri",
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                },
                "url": {
                  "type": "string"
                }
              },
              "type": "object"
            },
            "type": "array"
          },
          "success": {
            "type": "boolean"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "contact": {
      "email": "support@firecrawl.dev",
      "name": "Firecrawl Support",
      "url": "https://firecrawl.dev/support"
    },
    "description": "用于与 Firecrawl 服务交互并执行网页抓取和爬取任务的 API。",
    "title": "Firecrawl API",
    "version": "v0"
  },
  "openapi": "3.0.0",
  "paths": {
    "/crawl": {
      "post": {
        "operationId": "crawlUrls",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "crawlerOptions": {
                    "properties": {
                      "allowBackwardCrawling": {
                        "default": false,
                        "description": "使爬虫能够从特定 URL 导航到之前已链接的页面。例如，从 “example.com/product/123” 跳转回 “example.com/product”。",
                        "type": "boolean"
                      },
                      "allowExternalContentLinks": {
                        "default": false,
                        "description": "使爬虫可以跟随链接跳转到外部网站。",
                        "type": "boolean"
                      },
                      "excludes": {
                        "description": "需排除的 URL 模式",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "generateImgAltText": {
                        "default": false,
                        "description": "使用 LLM 为图像生成替代文本（需付费套餐）",
                        "type": "boolean"
                      },
                      "ignoreSitemap": {
                        "default": false,
                        "description": "抓取时忽略网站站点地图",
                        "type": "boolean"
                      },
                      "includes": {
                        "description": "要包含的 URL 模式",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "limit": {
                        "default": 10000,
                        "description": "最多爬取页面数",
                        "type": "integer"
                      },
                      "maxDepth": {
                        "description": "相对于输入 URL 的最大抓取深度。maxDepth 为 0 时仅抓取该 URL。maxDepth 为 1 时抓取该 URL 以及所有一层深度的页面。maxDepth 为 2 时抓取该 URL 以及所有最多两层深度的页面。更大的取值以此类推。",
                        "type": "integer"
                      },
                      "mode": {
                        "default": "default",
                        "description": "要使用的爬取模式。Fast 模式在没有 sitemap 的网站上爬取速度可提升约 4 倍，但结果可能不够准确，且不应在大量依赖 JS 渲染的网站上使用。",
                        "enum": [
                          "default",
                          "fast"
                        ],
                        "type": "string"
                      },
                      "returnOnlyUrls": {
                        "default": false,
                        "description": "如果为 true，则在抓取状态中仅返回 URL 列表。注意：返回的响应数据中包含的是一个由 URL 组成的列表，而不是文档列表。",
                        "type": "boolean"
                      }
                    },
                    "type": "object"
                  },
                  "pageOptions": {
                    "properties": {
                      "fullPageScreenshot": {
                        "default": false,
                        "description": "请附上你正在抓取页面的全页截图。",
                        "type": "boolean"
                      },
                      "headers": {
                        "description": "在请求中携带的请求头。可用于发送 Cookies、User-Agent 等信息。",
                        "type": "object"
                      },
                      "includeHtml": {
                        "default": false,
                        "description": "在页面中包含内容的 HTML 版本。响应中会返回一个名为 html 的键。",
                        "type": "boolean"
                      },
                      "includeRawHtml": {
                        "default": false,
                        "description": "在响应中包含页面的原始 HTML 内容。响应中将返回一个名为 rawHtml 的键。",
                        "type": "boolean"
                      },
                      "onlyIncludeTags": {
                        "description": "最终输出中仅包含页面中存在的标签、class 和 id。使用逗号分隔的值。示例：'script, .ad, #footer'",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "onlyMainContent": {
                        "default": false,
                        "description": "仅返回页面的主要内容，不包括页眉、导航栏、页脚等部分。",
                        "type": "boolean"
                      },
                      "removeTags": {
                        "description": "要从页面中移除的标签、类和 ID。使用逗号分隔的值。示例：'script, .ad, #footer'",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "replaceAllPathsWithAbsolutePaths": {
                        "default": false,
                        "description": "将所有图片和链接中的相对路径替换为绝对路径",
                        "type": "boolean"
                      },
                      "screenshot": {
                        "default": false,
                        "description": "请附上一张你要抓取的页面顶部截图。",
                        "type": "boolean"
                      },
                      "waitFor": {
                        "default": 0,
                        "description": "在获取内容前，先等待页面加载指定的毫秒数",
                        "type": "integer"
                      }
                    },
                    "type": "object"
                  },
                  "url": {
                    "description": "用于开始爬取的基础 URL",
                    "format": "uri",
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CrawlResponse"
                }
              }
            },
            "description": "成功的响应"
          },
          "402": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Payment required to access this resource.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "需要付费"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Request rate limit exceeded. Please wait and try again later.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "请求过于频繁"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "An unexpected error occurred on the server.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "服务器错误"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "基于选项抓取多个 URL",
        "tags": [
          "Crawling"
        ]
      }
    },
    "/crawl/cancel/{jobId}": {
      "delete": {
        "operationId": "cancelCrawlJob",
        "parameters": [
          {
            "description": "爬取任务 ID",
            "in": "path",
            "name": "jobId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "status": {
                      "description": "退货已取消。",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "成功的响应"
          },
          "402": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Payment required to access this resource.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "需要付费"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Request rate limit exceeded. Please wait and try again later.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "请求过多"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "An unexpected error occurred on the server.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "服务器错误"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "取消抓取任务",
        "tags": [
          "Crawl"
        ]
      }
    },
    "/crawl/status/{jobId}": {
      "get": {
        "operationId": "getCrawlStatus",
        "parameters": [
          {
            "description": "抓取任务 ID",
            "in": "path",
            "name": "jobId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "current": {
                      "description": "当前页码",
                      "type": "integer"
                    },
                    "data": {
                      "description": "任务返回的数据（执行中时为 null）",
                      "items": {
                        "$ref": "#/components/schemas/CrawlStatusResponseObj"
                      },
                      "type": "array"
                    },
                    "partial_data": {
                      "description": "在爬取过程中会以流式方式返回部分文档。**此功能当前处于 alpha 阶段——可能会有不兼容变更**。当某个页面准备就绪时，它会被追加到 `partial_data` 数组中，因此无需等待整个网站全部爬取完成。当爬取结束时，`partial_data` 将变为空，完整结果会出现在 `data` 中。数组响应最多包含 50 个元素；当有新元素加入数组时，最旧的元素（数组开头）会被移除。",
                      "items": {
                        "$ref": "#/components/schemas/CrawlStatusResponseObj"
                      },
                      "type": "array"
                    },
                    "status": {
                      "description": "任务状态（已完成、进行中、失败、已暂停）",
                      "type": "string"
                    },
                    "total": {
                      "description": "页面总数",
                      "type": "integer"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "成功响应"
          },
          "402": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Payment required to access this resource.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "需要付费"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Request rate limit exceeded. Please wait and try again later.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "请求过于频繁"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "An unexpected error occurred on the server.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "服务器错误"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "获取爬取任务状态",
        "tags": [
          "Crawl"
        ]
      }
    },
    "/scrape": {
      "post": {
        "operationId": "scrapeAndExtractFromUrl",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "extractorOptions": {
                    "default": {},
                    "description": "用于从页面内容中提取结构化信息的选项。注意：基于 LLM 的提取不会自动执行，只有在显式配置时才会运行。“markdown” 模式仅返回抓取到的 Markdown 内容，是抓取时的默认模式。",
                    "properties": {
                      "extractionPrompt": {
                        "description": "用于描述应从页面中提取哪些信息的提示，在 LLM 提取模式下使用。",
                        "type": "string"
                      },
                      "extractionSchema": {
                        "additionalProperties": true,
                        "description": "要提取数据的 schema，仅在 LLM 提取模式下才需要。",
                        "required": [
                          "company_mission",
                          "supports_sso",
                          "is_open_source"
                        ],
                        "type": "object"
                      },
                      "mode": {
                        "description": "要使用的提取模式。'markdown'：返回抓取到的 Markdown 内容，不执行 LLM 提取。'llm-extraction'：使用 LLM 从清洗和解析后的内容中提取信息。'llm-extraction-from-raw-html'：使用 LLM 直接从原始 HTML 中提取信息。'llm-extraction-from-markdown'：使用 LLM 从 Markdown 内容中提取信息。",
                        "enum": [
                          "markdown",
                          "llm-extraction",
                          "llm-extraction-from-raw-html",
                          "llm-extraction-from-markdown"
                        ],
                        "type": "string"
                      }
                    },
                    "type": "object"
                  },
                  "pageOptions": {
                    "properties": {
                      "fullPageScreenshot": {
                        "default": false,
                        "description": "附上你正在抓取页面的整页截图。",
                        "type": "boolean"
                      },
                      "headers": {
                        "description": "随请求发送的请求头。可用于传递 cookies、User-Agent 等信息。",
                        "type": "object"
                      },
                      "includeHtml": {
                        "default": false,
                        "description": "在页面中包含该内容的 HTML 版本。响应中会返回一个名为 html 的字段。",
                        "type": "boolean"
                      },
                      "includeRawHtml": {
                        "default": false,
                        "description": "在响应中包含页面的原始 HTML 内容。响应中将包含一个 rawHtml 字段。",
                        "type": "boolean"
                      },
                      "onlyIncludeTags": {
                        "description": "在最终输出中只包含页面中已有的标签、class 和 id。使用逗号分隔的值。示例：'script, .ad, #footer'",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "onlyMainContent": {
                        "default": false,
                        "description": "只返回页面的主体内容，不包括页眉、导航栏、页脚等。",
                        "type": "boolean"
                      },
                      "removeTags": {
                        "description": "要从页面中移除的标签、class 和 id。使用逗号分隔多个值。示例：'script, .ad, #footer'",
                        "items": {
                          "type": "string"
                        },
                        "type": "array"
                      },
                      "replaceAllPathsWithAbsolutePaths": {
                        "default": false,
                        "description": "将所有图像和链接中的相对路径替换为绝对路径",
                        "type": "boolean"
                      },
                      "screenshot": {
                        "default": false,
                        "description": "请附上一张所抓取页面顶部的截图。",
                        "type": "boolean"
                      },
                      "waitFor": {
                        "default": 0,
                        "description": "等待页面加载指定的毫秒时间后再获取内容",
                        "type": "integer"
                      }
                    },
                    "type": "object"
                  },
                  "timeout": {
                    "default": 30000,
                    "description": "请求超时时间（毫秒）",
                    "type": "integer"
                  },
                  "url": {
                    "description": "要抓取的 URL 地址",
                    "format": "uri",
                    "type": "string"
                  }
                },
                "required": [
                  "url"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeResponse"
                }
              }
            },
            "description": "成功响应"
          },
          "402": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Payment required to access this resource.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "需要付费"
          },
          "429": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "Request rate limit exceeded. Please wait and try again later.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "请求次数过多"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "error": {
                      "example": "An unexpected error occurred on the server.",
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "服务器错误"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "summary": "抓取单个 URL，并可选使用 LLM 进行信息抽取",
        "tags": [
          "Scraping"
        ]
      }
    },
    "/search": {
      "post": {
        "operationId": "searchGoogle",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "pageOptions": {
                    "properties": {
                      "fetchPageContent": {
                        "default": true,
                        "description": "获取每个页面的内容。如果为 false，则退回使用基础的快速 SERP API。",
                        "type": "boolean"
                      },
                      "includeHtml": {
                        "default": false,
                        "description": "在页面中包含内容的 HTML 版本。响应中会包含一个名为 html 的字段。",
                        "type": "boolean"
                      },
                      "includeRawHtml": {
                        "default": false,
                        "description": "在结果中包含页面的原始 HTML 内容。响应中将返回一个 rawHtml 键。",
                        "type": "boolean"
                      },
                      "onlyMainContent": {
                        "default": false,
                        "description": "仅返回页面的主要内容，不包括页眉、导航栏、页脚等。",
                        "type": "boolean"
                      }
                    },
                    "type": "object"
                  },
                  "query": {
                    "description": "要执行的搜索查询",
                    "format": "uri",
